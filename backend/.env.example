# Portal API
PORT=3001
# Comma-separated allowed origins for CORS (Vite dev server by default)
CORS_ORIGIN=http://localhost:5173

# Storage: local | s3   (azure planned)
STORAGE_PROVIDER=local
# local provider
LOCAL_STORAGE_DIR=.storage
# s3 provider — credentials come from the standard AWS env/profile chain
S3_BUCKET=
AWS_REGION=eu-west-3
